      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "owner": "modah237",
    "extra": {
      "eas": {
        "projectId": "7bbca034-1207-4f27-b74b-8b0044d2a698"
      }
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-secure-store"
    ]
  }
}
