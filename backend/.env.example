# ──────────────────────────────────────────────────────────
# AgriCollect CM — Backend — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS commiter .env en production
# ──────────────────────────────────────────────────────────

# ─── Application ────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Base de données (Supabase PostgreSQL) ──────────────────
# Obtenir depuis : Supabase Dashboard > Settings > Database > Connection string
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# ─── JWT ────────────────────────────────────────────────────
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_64_chars_minimum
JWT_REFRESH_SECRET=change_me_refresh_secret_64_chars_minimum

# ─── Campay (Paiements MoMo) ────────────────────────────────
# Obtenir depuis : https://campay.net > API Settings
CAMPAY_APP_USERNAME=
CAMPAY_APP_PASSWORD=
CAMPAY_BASE_URL=https://demo.campay.net/api  # Utiliser https://campay.net/api en production
CAMPAY_WEBHOOK_SECRET=                        # Signature HMAC des webhooks

# ─── Africa's Talking (SMS) ─────────────────────────────────
# Obtenir depuis : https://africastalking.com > Settings > API Key
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox              # Utiliser votre username en production
AFRICASTALKING_SENDER_ID=AgriCollect

# ─── Redis (BullMQ — Railway) ───────────────────────────────
# Obtenir depuis : Railway > Redis service > Connect
REDIS_URL=redis://localhost:6379

# ─── CORS ───────────────────────────────────────────────────
# URL du dashboard web (Next.js)
CORS_ORIGIN=http://localhost:3000
